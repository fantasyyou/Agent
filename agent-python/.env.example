# Copy this file to .env and replace the placeholder values.
DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

REDIS_PASSWORD=replace-with-a-strong-redis-password

# Optional Docker resource names. The defaults normally do not need to change.
AGENT_DOCKER_NETWORK=agent-network
REDIS_CONTAINER_NAME=agent-redis
ES_CONTAINER_NAME=es
PYTHON_CONTAINER_NAME=agent-python-customer-service
