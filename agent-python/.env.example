# Copy this file to .env and replace the placeholder values.
DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat
PYTHON_LOG_LEVEL=INFO
GO_LOG_LEVEL=INFO

# Optional published ports. Container names are fixed to match agent-go/config.json.
WEB_PORT=8081
PYTHON_DEBUG_PORT=8080
AGENT_NETWORK_NAME=agent-network

# MySQL is created independently using 虚拟机初始化操作.md.
MYSQL_CONTAINER_NAME=mysql
MYSQL_ROOT_PASSWORD=mysql-root-password
MYSQL_DSN='agent_user:agent-password@tcp(mysql:3306)/agent?parseTime=true&charset=utf8mb4&loc=UTC'

# Replace this in non-demo environments with at least 32 random characters.
AUTH_SIGNING_SECRET=demo-only-change-this-signing-secret-32-chars
